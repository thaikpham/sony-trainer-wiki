# Sony Training Wiki — Environment variables
# Copy to .env.local and fill values. Do not commit .env.local.
# See README.md and ROADMAP.md for setup.

# === SUPABASE (required) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only: sync-clerk, API routes that need service role
SUPABASE_SERVICE_ROLE_KEY=

# === CLERK AUTH (required) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === GEMINI AI (required for AI features) ===
GEMINI_API_KEY=

# === MCP (optional: external MCP server URL used by recommend flow) ===
MCP_SERVER_URL=

# === ADMIN (optional: protect sync-clerk and sync-knowledge APIs) ===
ADMIN_SECRET_KEY=

# === PINECONE (optional: only for packages/mcp-server, not Next.js app) ===
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=
